rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Allow anyone to check if phone or nationalId already exists (for signup duplicate check)
      allow read: if true;

      // Only the authenticated owner can write their own document
      allow write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
